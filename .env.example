NOWPAYMENTS_API_KEY=tu_api_key_privada
NOWPAYMENTS_PUBLIC_KEY=tu_clave_publica
NOWPAYMENTS_IPN_SECRET=tu_ipn_secret_de_nowpayments
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# PayPal: Client ID y Secret deben ser de la MISMA app en developer.paypal.com (pestaña Sandbox o Live).
# Opcional: si no definis PAYPAL_CLIENT_ID, se usa NEXT_PUBLIC_PAYPAL_CLIENT_ID.
PAYPAL_CLIENT_ID=tu_paypal_client_id
PAYPAL_SECRET=tu_paypal_secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=tu_mismo_client_id_visible
# Producción (Vercel) con credenciales de PRUEBA (Sandbox):
# PAYPAL_SANDBOX=true
# Local con credenciales LIVE (raro):
# PAYPAL_LIVE_DEV=true
# Con `next dev` el servidor usa API Sandbox por defecto (no hace falta PAYPAL_SANDBOX en .env.local).
